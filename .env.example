# .env.example — copy to .env.local and fill in values

# ── Toss auth / backend ───────────────────────────────────────────
# 토스 콘솔 → 미니앱 → 로그인 설정에서 발급받은 키들
TOSS_API_KEY=                  # 콘솔에서 발급된 API 키 (URL-safe base64 형식)
TOSS_DECRYPT_KEY=              # AES-256-GCM 복호화 키 (Base64)
TOSS_DECRYPT_AAD=TOSS          # 복호화 AAD (Additional Authenticated Data, UTF-8 평문)
TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im

# mTLS for Toss OAuth login token exchange + login-me API
# Base64로 인코딩된 인증서 + 키 사용 (Vercel 배포용)
TOSS_MTLS_CERT_BASE64=
TOSS_MTLS_KEY_BASE64=

# Legacy/optional — 일부 토스 SDK 흐름에서 OAuth client 정보 사용
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

JWT_SECRET=your-random-secret-here

# Toss unlink callback Basic Auth (콘솔 → 로그인 설정 → 콜백 비밀값)
# 형식: base64(서비스명:콜백비밀값)
# 예) echo -n "타키0415:xxxxxxxx" | base64
TOSS_UNLINK_CALLBACK_AUTH=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Client ────────────────────────────────────────────────────────
VITE_API_URL=

# ── AppsInToss Ad Group IDs (production) ──────────────────────────
# Leave blank to fall back to official test IDs.
# Issue at: https://developers-apps-in-toss.toss.im → 워크스페이스 → 미니앱 → 광고
# Format: ait.v2.live.XXXXXXXXXXXX
VITE_BANNER_AD_TEXT_ID=    # 텍스트 배너 (Home 페이지)
VITE_BANNER_AD_IMAGE_ID=   # 네이티브 이미지 배너 (Ranking 페이지)
VITE_REWARDED_AD_GROUP_ID= # 보상형 전면광고 (코인 +50)
VITE_INTERSTITIAL_AD_GROUP_ID= # 일반 전면광고

# ── 똥코인 → 토스포인트 교환 ──────────────────────────────────────
# mock | production
# - mock: DB only (no real Toss point grant) — for development
# - production: calls Toss promotion API with mTLS (requires all fields below)
EXCHANGE_MODE=mock
TOSS_PROMOTION_CODE=
# mTLS credentials (Base64-encoded cert + key, used for Toss promotion API)
TOSS_MTLS_CERT_BASE64=
TOSS_MTLS_KEY_BASE64=
